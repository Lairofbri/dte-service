# =============================================
# DTE SERVICE — Variables de entorno
# Una instancia = un cliente (un NIT)
# =============================================

# Servidor
NODE_ENV=development
PORT=4000

# Base de datos PostgreSQL (Railway)
DATABASE_URL=postgresql://usuario:password@host:5432/dte_db

# ─────────────────────────────────────────────
# SEGURIDAD DEL SERVICIO
# ─────────────────────────────────────────────

# API Key que el POS usa para autenticarse con este servicio
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
API_KEY_HASH=hash_bcrypt_de_la_api_key_del_cliente

# Clave AES-256 para encriptar credenciales sensibles en BD
# Debe tener exactamente 32 caracteres
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
ENCRYPTION_KEY=clave_de_32_caracteres_exactos_aqui

# ─────────────────────────────────────────────
# DATOS DEL EMISOR (el restaurante cliente)
# ─────────────────────────────────────────────
NIT_EMISOR=0000-000000-000-0
NRC_EMISOR=000000-0
NOMBRE_EMISOR=Nombre del Restaurante
NOMBRE_COMERCIAL=Nombre Comercial
DIRECCION_EMISOR=Dirección completa
TELEFONO_EMISOR=0000-0000
EMAIL_EMISOR=contacto@restaurante.com
CODIGO_ACTIVIDAD=47111
CODIGO_ESTABLECIMIENTO=0001
CODIGO_PUNTO_VENTA=0001
TIPO_ESTABLECIMIENTO=02

# ─────────────────────────────────────────────
# HACIENDA — API de transmisión
# ─────────────────────────────────────────────
# 00 = pruebas, 01 = producción
AMBIENTE_HACIENDA=00
URL_AUTH_HACIENDA=https://apitest.dtes.mh.gob.sv/seguridad/auth
URL_RECEPCION_HACIENDA=https://apitest.dtes.mh.gob.sv/fesv/recepciondte
URL_CONSULTA_HACIENDA=https://apitest.dtes.mh.gob.sv/fesv/recepcion/consultadte/
URL_CONTINGENCIA_HACIENDA=https://apitest.dtes.mh.gob.sv/fesv/contingencia
URL_ANULACION_HACIENDA=https://apitest.dtes.mh.gob.sv/fesv/anulardte

# Credenciales API de Hacienda (las que el cliente obtiene en el acreditamiento)
# Se guardan encriptadas en BD, estas son solo para el setup inicial
USUARIO_HACIENDA=NIT_SIN_GUIONES
PASSWORD_HACIENDA=password_api_hacienda

# Timeout en ms para llamadas a Hacienda (manual dice 8 segundos)
TIMEOUT_HACIENDA=8000
# Máximo de reintentos antes de entrar en contingencia
MAX_REINTENTOS_HACIENDA=2

# ─────────────────────────────────────────────
# FIRMADOR — Servicio de firma electrónica
# Docker o Windows Service del Ministerio de Hacienda
# ─────────────────────────────────────────────
URL_FIRMADOR=http://localhost:8113/firmardocumento/
TIMEOUT_FIRMADOR=10000

# ─────────────────────────────────────────────
# ALMACENAMIENTO — S3/R2 para JSON de DTEs
# ─────────────────────────────────────────────
# Cloudflare R2 (recomendado) o AWS S3
S3_ENDPOINT=https://tu-account.r2.cloudflarestorage.com
S3_BUCKET=dte-json
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# CORS — solo el POS puede consumir este servicio
CORS_ORIGINS=http://localhost:3000

# Logs
LOG_LEVEL=info
